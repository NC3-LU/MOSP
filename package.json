        "bootstrap": "^5.3.3",
        "chart.js": "^4.4.3",
        "chartjs-plugin-datalabels": "^2.2.0",
        "code-prettify": "^0.1.0",
        "datatables": "^1.10.18",
        "datatables.net-bs4": "^2.1.3",
        "jquery": "^3.7.1",
